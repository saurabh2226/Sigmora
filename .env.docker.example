BACKEND_IMAGE=ghcr.io/your-github-user/sigmora-backend:latest
FRONTEND_IMAGE=ghcr.io/your-github-user/sigmora-frontend:latest

BACKEND_HOST_PORT=5000
FRONTEND_HOST_PORT=80
REDIS_HOST_PORT=6379

NODE_ENV=production
CLIENT_URL=https://app.example.com
CLIENT_URLS=https://app.example.com,https://preview-app.example.com
ALLOW_VERCEL_PREVIEWS=false
ALLOW_LOCALHOST_ORIGINS=false
COOKIE_SAMESITE=none
COOKIE_SECURE=true
TRUST_PROXY=true
VITE_API_URL=https://api.example.com/api/v1
VITE_RAZORPAY_KEY_ID=rzp_live_replace_me
VITE_GOOGLE_MAPS_KEY=replace_me

MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/hotel-booking?retryWrites=true&w=majority

# Option A (preferred for managed MySQL): provide full URI
MYSQL_URI=
# Option B: host/port/user/password/database fields
MYSQL_HOST=your-aiven-host
MYSQL_PORT=12345
MYSQL_USER=avnadmin
MYSQL_PASSWORD=replace_me
MYSQL_DATABASE=Sigmora_db
MYSQL_SSL=true
MYSQL_SSL_REJECT_UNAUTHORIZED=true
MYSQL_SSL_CA=
MYSQL_SSL_CA_BASE64=
MYSQL_SSL_CA_PATH=/etc/secrets/aiven-ca.pem
SQL_SCHEMA_SYNC=true
SQL_SCHEMA_ALTER=false

REDIS_URL=redis://redis:6379
REDIS_LOCK_TTL_MS=15000
REDIS_LOCK_WAIT_MS=5000
REDIS_LOCK_RETRY_MS=120

JWT_ACCESS_SECRET=replace_with_secure_access_secret
JWT_REFRESH_SECRET=replace_with_secure_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

RAZORPAY_KEY_ID=rzp_live_replace_me
RAZORPAY_KEY_SECRET=replace_me
RAZORPAY_WEBHOOK_SECRET=replace_me

CLOUDINARY_CLOUD_NAME=replace_me
CLOUDINARY_API_KEY=replace_me
CLOUDINARY_API_SECRET=replace_me

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=replace_me
EMAIL_PASS=replace_me
EMAIL_REQUIRE_TLS=false
EMAIL_FROM=noreply@sigmora.com

GOOGLE_CLIENT_ID=replace_me
GOOGLE_CLIENT_SECRET=replace_me
GOOGLE_CALLBACK_URL=https://api.example.com/api/v1/auth/google/callback

BOOKING_HOLD_MINUTES=10
SEED_PENDING_HOLD_DAYS=120
