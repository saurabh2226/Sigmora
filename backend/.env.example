NODE_ENV=development
PORT=5000
TRUST_PROXY=false

# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27018/hotel-booking

# MySQL / SQL Mirror
# Option A: set MYSQL_URI (recommended for managed providers such as Aiven)
MYSQL_URI=
# Option B: set host/port/user/password/database fields below
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=Sigmora_db
MYSQL_SSL=false
MYSQL_SSL_REJECT_UNAUTHORIZED=false
# Optional CA certificate for strict SSL mode on managed MySQL (Aiven)
MYSQL_SSL_CA=
MYSQL_SSL_CA_BASE64=
MYSQL_SSL_CA_PATH=
SQL_SCHEMA_SYNC=true
SQL_SCHEMA_ALTER=false

# JWT
JWT_ACCESS_SECRET=your_access_secret_key_here
JWT_REFRESH_SECRET=your_refresh_secret_key_here
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Razorpay
RAZORPAY_KEY_ID=rzp_test_your_key
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret
BOOKING_HOLD_MINUTES=10
SEED_PENDING_HOLD_DAYS=120

# Redis (optional but recommended for distributed room-booking locks)
REDIS_URL=redis://127.0.0.1:6379
REDIS_LOCK_TTL_MS=15000
REDIS_LOCK_WAIT_MS=5000
REDIS_LOCK_RETRY_MS=120

# Email (Nodemailer SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your_email@example.com
EMAIL_PASS=your_email_app_password
EMAIL_FROM=noreply@hotelbooking.com

# Client URL
# Primary frontend URL (used for redirects + email links)
CLIENT_URL=http://localhost:5173
# Optional comma-separated allowlist for additional origins (for CORS/socket)
CLIENT_URLS=
ALLOW_VERCEL_PREVIEWS=false
ALLOW_LOCALHOST_ORIGINS=true

# Cookie settings
COOKIE_SAMESITE=lax
COOKIE_SECURE=false

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/v1/auth/google/callback
